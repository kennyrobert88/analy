# ─────────────────────────────────────────────────────────────────────────────
# Analy — Production Environment Variables
#
# Copy this file to .env.production, fill in every value, and NEVER commit
# .env.production to version control.
#
# Key generation commands are included inline for each secret.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── Database ──────────────────────────────────────────────────────────────────
# Absolute path inside the container (maps to the db_data Docker volume)
DB_PATH=/data/emails.db

# ── Encryption ───────────────────────────────────────────────────────────────
# AES-256-GCM key for OAuth token encryption at rest.
# Must be exactly 32 bytes base64-encoded (44 chars).
#
# Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
ENCRYPTION_KEY=REPLACE_ME_WITH_32_BYTE_BASE64_KEY

# Previous encryption key — set this during key rotation so existing rows can
# still be decrypted while new writes use ENCRYPTION_KEY.
# Remove after all rows have been re-encrypted.
# ENCRYPTION_KEY_PREV=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Secret for signing access + refresh tokens (HS256).
# Should be at least 32 random bytes base64-encoded.
#
# Generate:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
#
JWT_SECRET=REPLACE_ME_WITH_48_BYTE_BASE64_SECRET

# ── Google OAuth ──────────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials
# Redirect URI must be registered: http://localhost:3000/oauth2callback
#
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your frontend URL/s)
# Example: https://app.yourdomain.com,https://yourdomain.com
ALLOWED_ORIGINS=https://app.yourdomain.com

# ── Optional: HMAC signing for non-encrypted fields ──────────────────────────
# Defaults to ENCRYPTION_KEY if not set.
# HMAC_SECRET=
